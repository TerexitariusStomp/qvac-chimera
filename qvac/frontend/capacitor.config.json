{
  "appId": "io.chimera.mobile",
  "appName": "Chimera",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a14",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    }
  },
  "android": {
    "path": "../../apps/mobile/android",
    "buildOptions": {
      "releaseType": "AAB"
    }
  },
  "ios": {
    "path": "../../apps/mobile/ios",
    "contentInset": "always"
  }
}
