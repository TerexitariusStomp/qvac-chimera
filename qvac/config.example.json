{
  "node": {
    "id": "generate-with-crypto.randomUUID()",
    "name": "Chimera Mining Node",
    "version": "1.0.0",
    "publicUrl": "https://your-node-domain.com"
  },
  "inference": {
    "enabled": true,
    "qvac": {
      "endpoint": "local",
      "models": [
        "llama-3.2-1b-instruct"
      ],
      "modelConst": "LLAMA_3_2_1B_INST_Q4_0",
      "maxConcurrent": 4
    },
    "localLLM": {
      "model": "llama-3.2-1b-instruct",
      "qvacModelConst": "LLAMA_3_2_1B_INST_Q4_0",
      "timeout": 300000
    },
    "embedding": {
      "model": "EMBEDDINGGEMMA_300M_Q4_0",
      "qvacModelConst": "EMBEDDINGGEMMA_300M_Q4_0",
      "device": "cpu",
      "workspace": "chimera-rag"
    },
    "idleTimeout": 300000
  },
  "miners": {
    "enabled": true,
    "parallelMode": true,
    "priority": [
      "cortensor",
      "routstr",
      "chutes",
      "fortytwo",
      "earnidle"
    ],
    "switchInterval": 60000,
    "cortensor": {
      "enabled": true,
      "note": "Cortensor network miner. Register: https://github.com/cortensor/installer",
      "config": {
        "network": "arbitrum",
        "walletAddress": "0xYOUR_EVM_WALLET_ADDRESS",
        "protocolAddress": "",
        "cortensorHome": "~/.cortensor",
        "envFile": "~/.cortensor/.env",
        "cortensordPath": "",
        "autoFundSweep": true
      }
    },
    "fortytwo": {
      "enabled": true,
      "config": {
        "network": "evm",
        "platform": "https://fortytwo.network",
        "walletAddress": "0xYOUR_EVM_WALLET_ADDRESS",
        "protocolAddress": "",
        "nodeName": "Chimera-Fortytwo-Node",
        "apiBase": "https://node.fortytwo.network/api",
        "inferenceUrl": "https://your-node-domain.com:3002/v1",
        "pollInterval": 120000,
        "fortytwoHome": "~/.fortytwo",
        "autoFundSweep": true
      }
    },
    "earnidle": {
      "enabled": true,
      "config": {
        "network": "solana",
        "walletAddress": "YOUR_SOLANA_WALLET_ADDRESS",
        "protocolAddress": "",
        "nodeName": "Chimera-IDLE-Inference",
        "model": "llama-3.2-1b-instruct",
        "gpuAvailable": false,
        "pollInterval": 30000,
        "apiBase": "https://api.earnidle.com",
        "autoFundSweep": true
      }
    },
    "routstr": {
      "enabled": true,
      "config": {
        "network": "nostr",
        "platform": "https://routstr.com",
        "nsec": "nsec1YOUR_NOSTR_PRIVATE_KEY",
        "npub": "npub1YOUR_NOSTR_PUBLIC_KEY",
        "name": "Chimera-Routstr-Node",
        "description": "QVAC-Chimera decentralized AI inference node",
        "receiveLnAddress": "you@your-lightning-wallet.com",
        "adminPassword": "GENERATE_A_STRONG_RANDOM_PASSWORD",
        "apiPort": 8000,
        "autoFundSweep": true
      }
    },
    "chutes": {
      "enabled": true,
      "config": {
        "network": "bittensor",
        "platform": "https://chutes.ai",
        "walletAddress": "YOUR_BITTENSOR_COLDKEY_SS58",
        "hotkeyAddress": "YOUR_BITTENSOR_HOTKEY_SS58",
        "mnemonic": "YOUR TWELVE WORD BITTENSOR MNEMONIC PHRASE HERE",
        "apiKey": "cpk_YOUR_CHUTES_API_KEY",
        "apiBaseUrl": "https://api.chutes.ai",
        "inferenceBaseUrl": "https://llm.chutes.ai/v1",
        "chutesHome": "~/.chutes",
        "endpoint": "https://your-node-domain.com:3002/v1"
      }
    },
    "casper": {
      "enabled": true,
      "config": {
        "network": "casper",
        "rpcUrl": "https://rpc.mainnet.casper.network/rpc",
        "providerKeyPem": ""
      }
    }
  },
  "multisig": {
    "enabled": true,
    "machineOwnerAddress": "0xYOUR_MACHINE_OWNER_EVM_ADDRESS",
    "appDeveloperAddress": "0xYOUR_APP_DEVELOPER_EVM_ADDRESS",
    "evmCollectionAddress": "0xYOUR_EVM_COLLECTION_MULTISIG_ADDRESS",
    "rpcUrl": "https://arb1.arbitrum.io/rpc",
    "_note_signingKey": "Set PAYOUT_SIGNING_KEY env var — never put private keys in this file",
    "revenueSplit": {
      "machineOwner": 0.7,
      "appDeveloper": 0.3
    },
    "weeklySweep": {
      "enabled": true,
      "dayOfWeek": 0,
      "hour": 0,
      "minute": 0,
      "denialWindowHours": 48,
      "description": "Collects all network funds into EVM collection multisig"
    },
    "monthlySweep": {
      "enabled": true,
      "dayOfMonth": 1,
      "hour": 0,
      "minute": 0,
      "denialWindowHours": 48,
      "description": "Distributes from EVM collection multisig to machineOwnerAddress and appDeveloperAddress"
    },
    "protocolMultisigs": {
      "nostr": {
        "enabled": true,
        "protocol": "cashu-nip60-p2sh",
        "address": "npub1YOUR_NOSTR_MULTISIG_ADDRESS",
        "threshold": 2,
        "signers": 3
      },
      "bittensor": {
        "enabled": true,
        "protocol": "substrate-multisig",
        "address": "YOUR_BITTENSOR_MULTISIG_SS58_ADDRESS",
        "threshold": 2,
        "signers": 3
      },
      "solana": {
        "enabled": true,
        "protocol": "spl-multisig",
        "address": "YOUR_SOLANA_MULTISIG_ADDRESS",
        "threshold": 2,
        "signers": 3
      }
    }
  },
  "scheduler": {
    "enabled": true,
    "nightStart": 20,
    "nightEnd": 6,
    "timezone": "UTC"
  },
  "swarm": {
    "enabled": true,
    "inference": {
      "enabled": true,
      "commanderUrl": "https://your-node-domain.com:3002",
      "role": "commander",
      "workerPollInterval": 5000,
      "workerRegisterInterval": 30000
    }
  },
  "p2p": {
    "enabled": true,
    "pear": {
      "enabled": true,
      "discovery": true
    },
    "hypercore": {
      "storage": "./data/hypercore",
      "replicate": true
    }
  },
  "storage": {
    "path": "./data",
    "encryption": true
  },
  "auth": {
    "method": "signin",
    "required": true
  }
}
